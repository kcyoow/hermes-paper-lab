import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const sourceFigures = [
  {
    id: '원문 그림 1 — 파라미터 효율 비교',
    src: 'images/papers/vb-lora/figures/figure-1-parameter-efficiency.png',
    caption: 'RoBERTa-Large에서 PEFT 방법들을 비교한 그림입니다. VB-LoRA는 더 적은 저장 파라미터로 더 높은 점수를 달성한다고 보고합니다.',
    reading: 'x축은 저장 파라미터 수, y축은 성능 점수로 읽으면 됩니다. 핵심은 VB-LoRA가 “작은 저장량 영역”에 있으면서도 높은 점수 위치에 있다는 점입니다. 단, 이 그림은 해당 RoBERTa-Large/GLUE 설정의 결과이지 모든 태스크 보장은 아닙니다.'
  },
  {
    id: '원문 그림 2 — VB-LoRA 구조',
    src: 'images/papers/vb-lora/figures/figure-2-architecture.png',
    wide: true,
    caption: '왼쪽은 모델 파라미터가 vector bank의 벡터 조합으로 표현될 수 있음을 보여주고, 오른쪽은 top-k softmax로 k개 벡터를 골라 sub-vector를 만들고 이를 LoRA 파라미터 위치에 배치하는 구조를 보여줍니다.',
    reading: '논문 방법의 핵심 그림입니다. “LoRA 행렬 전체를 저장”하는 대신, 같은 길이의 조각을 공용 벡터 뱅크에서 골라 섞는다는 점을 보면 됩니다.'
  },
  {
    id: '원문 그림 3 — Top-k 선택 동역학',
    src: 'images/papers/vb-lora/figures/figure-3-topk-training-dynamics.png',
    wide: true,
    caption: 'k=1, k=2, k=3, noisy top-2에서 학습 중 vector selection footprint가 어떻게 달라지는지 보여줍니다. x축은 sub-vector, y축은 vector bank에서 선택된 벡터 인덱스입니다.',
    reading: 'k=1은 선택이 경직되기 쉽고, k=2/3은 더 많은 탐색이 보입니다. 절제 실험에서 top-2가 강한 이유를 직관적으로 보여주는 그림입니다.'
  },
  {
    id: '원문 그림 4 — 초기 선택과 최종 선택',
    src: 'images/papers/vb-lora/figures/figure-4-selection-init-final.png',
    wide: true,
    caption: '초기화 시점의 선택은 빨간색, 학습 종료 후 선택은 파란색, 겹치는 선택은 초록색으로 표시합니다.',
    reading: '많은 sub-vector의 최종 선택이 초기 선택과 달라집니다. 즉 vector bank 선택이 고정된 라우팅이 아니라 downstream 학습 중 실제로 바뀌는 학습 대상임을 보여줍니다.'
  },
  {
    id: '원문 그림 5 — 학습 구간별 선택 변화',
    src: 'images/papers/vb-lora/figures/figure-5-top2-epoch.png',
    caption: 'Top-2 설정에서 학습 시기별 vector selection footprint를 보여줍니다.',
    reading: '초기 학습 단계에서 탐색이 가장 활발하고 후반으로 갈수록 업데이트가 희소해지는 패턴을 봅니다. 이 그림은 VB-LoRA의 선택 메커니즘이 초기에 공간을 탐색한 뒤 안정화된다는 저자 해석을 뒷받침합니다.'
  },
  {
    id: '원문 그림 6 — 레이어 그룹별 벡터 사용',
    src: 'images/papers/vb-lora/figures/figure-6-layer-usage.png',
    caption: '각 vector bank 벡터의 top-k 가중치 합을 앞/중간/뒤 8개 레이어 그룹별로 묶어 보여줍니다.',
    reading: '일부 벡터가 특정 깊이의 레이어에서 더 많이 쓰일 수 있음을 봅니다. 이는 vector bank가 완전히 균일하게 쓰이는 창고가 아니라, 레이어별 역할 분화가 생길 수 있음을 시사합니다.'
  },
  {
    id: '원문 그림 7 — 모듈·행렬 유형별 벡터 사용',
    src: 'images/papers/vb-lora/figures/figure-7-module-usage.png',
    caption: 'query/value 모듈과 A/B 행렬 유형별로 vector bank 사용량을 묶어 보여줍니다.',
    reading: '예를 들어 특정 벡터가 A 행렬이나 Query 모듈에서 두드러지게 사용될 수 있습니다. sub-vector 공유가 “모든 곳에 똑같이 공유”가 아니라 역할별 선택 패턴을 학습한다는 근거입니다.'
  },
  {
    id: '원문 그림 8 — 벡터 사용 빈도 히스토그램',
    src: 'images/papers/vb-lora/figures/figure-8-usage-histogram.png',
    caption: 'Gemma-7B/MetaMathQA 설정에서 vector usage frequency가 대체로 정규분포처럼 퍼진다고 보고합니다.',
    reading: 'MoE류 모델에서 흔한 load balancing 문제를 걱정할 수 있는데, 이 그림은 극단적으로 일부 벡터만 쓰이는 붕괴가 관찰되지 않았다는 보조 근거입니다.'
  },
  {
    id: '원문 그림 9 — 벡터 뱅크와 sub-vector 시각화',
    src: 'images/papers/vb-lora/figures/figure-9-subvectors-simplex.png',
    caption: '학습된 vector bank와 sub-vector를 2차원으로 투영해 보여줍니다. sub-vector들이 vector bank가 이루는 simplex의 edge 근처에 배치되는 모습을 시각화합니다.',
    reading: '수식으로는 top-k convex mixture인데, 그림으로 보면 sub-vector가 공용 벡터들 사이의 조합 공간에 놓인다는 직관을 얻을 수 있습니다.'
  }
];
const mathNotes = [
  {
    id: '수식 1 — LoRA 업데이트의 저랭크 분해',
    formula: String.raw`\[\Delta W = B A, \qquad B \in \mathbb{R}^{m \times r},\; A \in \mathbb{R}^{r \times n},\; r \ll \min(m,n)\]`,
    explanation: ['LoRA는 원래 가중치 \(W_0\) 전체를 다시 학습하지 않고, 변화량 \(\Delta W\)만 작은 rank \(r\)의 두 행렬 곱으로 표현합니다.', '저장해야 하는 것은 전체 \(m \times n\) 행렬이 아니라 \(B\)와 \(A\)입니다. 그래서 저장량은 대략 \(r(m+n)\) 수준으로 줄어듭니다.']
  },
  {
    id: '수식 2 — rank-one outer product 합으로 다시 보기',
    formula: String.raw`\[\Delta W = B A = \sum_{k=1}^{r} b_k \otimes a_k = \sum_{k=1}^{r} \bigotimes_{i=1}^{2} v_k^{(i)},\quad v_k^{(1)}=b_k,\; v_k^{(2)}=a_k\]`,
    explanation: ['VB-LoRA의 출발점입니다. LoRA 행렬 곱을 rank별 outer product들의 합으로 풀어 쓰면, 각 rank component는 두 벡터 \(b_k\), \(a_k\)의 조합으로 볼 수 있습니다.', '이렇게 벡터 단위로 보면 다음 단계에서 벡터를 더 작은 sub-vector로 자를 수 있습니다. 즉 “행렬 공유”가 아니라 “벡터 조각 공유”로 내려가는 발판입니다.']
  },
  {
    id: '수식 3 — component vector를 sub-vector로 나누기',
    formula: String.raw`\[v_k^{(i)} = \operatorname{concat}\left(u_{k,1}^{(i)}, u_{k,2}^{(i)}, \ldots, u_{k,d_i'}^{(i)}\right),\qquad u_{k,j}^{(i)} \in \mathbb{R}^{b},\quad d_i'=d_i/b\]`,
    explanation: ['길이가 서로 다른 LoRA 벡터들을 바로 공유하기는 어렵습니다. 그래서 공통 길이 \(b\)의 sub-vector로 잘라 모두 같은 형식으로 맞춥니다.', '여기서 \(b\)는 sub-vector 길이입니다. 논문 절제 실험에서는 \(b=256\)이 CoLA 설정에서 가장 좋았습니다.']
  },
  {
    id: '수식 4 — vector bank의 top-k 혼합',
    formula: String.raw`\[u = \sum_{s=1}^{h} w_s(\sigma)\alpha_s,\qquad w(\sigma)=\operatorname{Softmax}(\operatorname{TopK}(\sigma,k))\]`,
    explanation: ['각 sub-vector \(u\)는 vector bank \(\mathcal{B}=\{\alpha_1,\ldots,\alpha_h\}\)에 있는 기본 벡터들의 가중합으로 만들어집니다.', 'TopK는 로짓 \(\sigma\) 중 큰 \(k\)개만 남기고 나머지는 \(-\infty\)로 보내 softmax 후 가중치가 0이 되게 합니다. 그래서 모든 벡터를 섞는 것이 아니라 소수 \(k\)개만 희소하게 섞습니다.']
  },
  {
    id: '수식 5 — 저장 파라미터 triplet',
    formula: String.raw`\[\Theta = \{\mathcal{B},\mathcal{I},\mathcal{V}\},\quad \mathcal{B}\in\mathbb{R}^{h\times b},\; \mathcal{I}\in\mathbb{R}^{2\times L\times M\times r\times(d/b)\times k},\; \mathcal{V}\in\mathbb{R}^{2\times L\times M\times r\times(d/b)\times(k-1)}\]`,
    explanation: ['학습 중에는 전체 로짓 \(\sigma\)가 필요하지만, 저장할 때는 선택된 인덱스 \(\mathcal{I}\)와 혼합 가중치 \(\mathcal{V}\), 그리고 공유 vector bank \(\mathcal{B}\)만 남길 수 있습니다.', '가중치가 \(k\)개인데 자유도는 \(k-1\)인 이유는 softmax 혼합 가중치의 합이 1이기 때문입니다. 마지막 하나는 나머지 값으로 결정됩니다.']
  },
  {
    id: '수식 6 — k=2, uint8 인덱스일 때 저장량',
    formula: String.raw`\[\#\text{stored params}_{\text{VB-LoRA}} \approx h b + 3 L M r(d/b)\]`,
    explanation: ['첫 항 \(hb\)는 공유 vector bank 자체입니다. 두 번째 항은 각 sub-vector가 선택한 인덱스와 혼합 가중치를 저장하는 비용입니다.', '논문의 요지는 두 번째 항의 계수 \(3r/b\)가 작다는 점입니다. 예를 들어 \(r=4, b=256\)이면 계수가 약 0.047이라, LoRA의 \(2r=8\)보다 훨씬 작습니다.']
  },
  {
    id: '수식 7 — forward 계산에서 ΔW를 명시적으로 만들지 않기',
    formula: String.raw`\[xW_0 + x\Delta W = xW_0 + xBA = xW_0 + (xB)A\]`,
    explanation: ['Algorithm 1의 계산 직관입니다. \(\Delta W=BA\)를 큰 행렬로 먼저 만들지 않고, \((xB)A\) 순서로 계산하면 메모리를 줄일 수 있습니다.', '이 부분은 추론 비용을 크게 늘리지 않기 위한 구현상 핵심입니다. 논문은 LoRA처럼 원래 모델 파라미터에 merge할 수 있으므로 inference overhead가 없다고 설명합니다.']
  }
];
const figureIndex = [
  ['원문 그림 1', 'RoBERTa-Large에서 PEFT 방법의 저장 파라미터 대비 성능 비교', 'VB-LoRA의 저장량 장점을 가장 직관적으로 보여줌', '해당 실험 설정 기준'],
  ['원문 그림 2', 'vector bank 공유와 top-k admixture 기반 VB-LoRA 구조', '논문 방법의 핵심 구조', '기존 LoRA를 사후 무손실 압축한다는 뜻은 아님'],
  ['원문 그림 3', 'k=1,2,3 및 noisy top-2의 vector selection footprint', '왜 k=2가 잘 작동하는지 직관 제공', 'CoLA/RoBERTa-large 설정 기준'],
  ['원문 그림 4', '초기 선택과 최종 선택 비교', '선택 로짓이 학습 중 실제로 바뀜을 보여줌', '시각화용 축약 설정'],
  ['원문 그림 5', '학습 구간별 vector selection footprint', '초기 탐색 후 후반 안정화 패턴', 'Top-2 설정 기준'],
  ['원문 그림 6', '레이어 그룹별 vector bank 사용량', '일부 벡터의 레이어별 역할 분화 가능성', 'RoBERTa/CoLA 시각화'],
  ['원문 그림 7', 'query/value 모듈 및 A/B 행렬별 사용량', '모듈·행렬 유형별 선택 패턴 확인', '사용량이 성능 원인을 완전히 설명하진 않음'],
  ['원문 그림 8', 'Gemma-7B vector usage histogram', 'load balancing 붕괴가 심하지 않다는 보조 근거', '정규분포처럼 보인다는 관찰'],
  ['원문 그림 9', 'vector bank와 sub-vector의 2D 투영', 'top-k convex mixture 직관 제공', 't-SNE 투영은 거리 해석에 주의'],
  ['표 1', 'RoBERTa base/large GLUE 결과', 'VB-LoRA가 적은 저장량으로 경쟁력 있는 평균 성능을 보임', '일부 baseline은 원 논문 수치, 일부는 저자 구현'],
  ['표 2', 'GPT-2 E2E 자연어 생성 결과', '생성 태스크에서도 저장량 절감 확인', 'VeRA와 비슷한 성능, 모든 지표에서 압도는 아님'],
  ['표 3', 'Llama 2 MT-Bench instruction tuning 결과', '0.8M/1.1M 저장 파라미터로 LoRA 대비 큰 절감', 'GPT-4 평가 모델 변화 가능성을 저자도 언급'],
  ['표 4', 'Mistral/Gemma 수학 추론 결과', 'GSM8K에서 강하고 저장량이 작음', 'MATH에서는 LoRA가 더 높은 설정도 있음'],
  ['수식 1', 'LoRA 업데이트 \(\Delta W=BA\)', 'VB-LoRA가 압축/재구성하려는 기본 대상', '전체 fine-tuning과 구분'],
  ['수식 4', 'sub-vector의 vector bank top-k 혼합', 'VB-LoRA의 share 단계 핵심', '저장 시 로짓 전체가 아니라 선택 인덱스/가중치만 남김'],
  ['수식 6', '저장량 \(hb+3LMr(d/b)\)', '왜 저장 파라미터가 극단적으로 줄어드는지 설명', 'k=2와 uint8 인덱스 가정']
];
