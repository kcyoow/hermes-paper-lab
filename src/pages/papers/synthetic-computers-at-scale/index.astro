const base = import.meta.env.BASE_URL;
const metrics = [
  ['Synthetic computers', '1,000', 'preliminary experiments에서 생성한 사용자별 synthetic computer 수'],
  ['Avg. files', '111.6 → 197.4', '한 달 시뮬레이션 전후 평균 파일 수 변화; 디렉터리 깊이는 거의 유지'],
  ['Avg. turns', '2,272', 'weekly planning 63 + daily execution 2,209 turns 평균'],
  ['Avg. runtime', '8.59h', '한 synthetic computer당 평균 wall-clock time'],
  ['Collaborators', '5.5', '평균 simulated collaborators; 평균 communication 31회'],
  ['Skill gain', '+7.0pp', 'in-domain: 61.6% → 68.6%, 83/100 computers에서 skill-augmented가 우세'],
  ['GDPVal OOD', '105 vs 67', 'Sonnet setting에서 skill-augmented wins/losses; p=0.002 one-sided, p=0.005 two-sided'],
  ['Released resources', '100 + 500', '100 synthetic computers 및 500 retrospective analysis reports 공개']
];
const figureIndex = [
  ['Figure 1', '전체 방법론 개요: persona → synthetic computer → long-horizon simulation → process/outcome signals'],
  ['Figure 2', 'persona를 detailed user profile, filesystem plan, artifacts로 확장하는 synthetic computer creation pipeline'],
  ['Figure 3', '생성된 artifact 예시: VCMM workbook 및 Capital Markets Outlook PDF'],
  ['Figure 4–5', '1,000 personas의 직업 분포 및 synthetic computer의 artifact type distribution'],
  ['Table 1', '시뮬레이션 전후 computer statistics: files 111.6 → 197.4, directories 30.4 → 36.0'],
  ['Table 2', 'DOCX/XLSX/PPTX/PDF 등 artifact file sizes; placeholder가 아닌 content-rich 파일임을 보여줌'],
  ['Table 3', '평균 2,272 turns, 8.59 hours, 5.5 collaborators, 31 communications'],
  ['Table 4', 'occupation-specific skills의 in-domain 개선: 61.6% → 68.6%, +7.0pp'],
  ['Table 5', 'GDPVal과 비교: 더 많은 files, deliverables, turns, runtime을 요구하는 setup'],
  ['Figure 8', 'GDPVal out-of-domain transfer 결과: Sonnet에서 105 wins vs 67 losses'],
  ['Figure 9', 'simulation → retrospective signals → skills → model improvement로 이어지는 self-improvement loop']
