---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SourceFigureSet from '../../../components/SourceFigureSet.astro';
import MathNoteSet from '../../../components/MathNoteSet.astro';

const sourceFigures = [
  {
    id: '원문 그림 1a — 속도와 정확도의 교환관계',
    src: 'https://wedlm.github.io/figs/fig1a.svg',
    caption: 'GSM8K에서 WeDLM-8B의 정확도와 초당 생성 토큰 수를 AR 및 diffusion 기준선과 비교합니다. 저자들은 vLLM으로 실행한 Qwen3-8B보다 약 3배 빠르면서 더 높은 정확도를 얻었다고 보고합니다.',
    reading: '오른쪽 위에 가까울수록 빠르고 정확합니다. 단, 각 diffusion 기준선은 저자들이 권장하는 서로 다른 엔진을 사용하므로 “모델 구조만의 순수 비교”라기보다 실제 배포 스택을 포함한 비교입니다.'
  },
  {
    id: '원문 그림 1b — 전체 능력 비교',
    src: 'https://wedlm.github.io/figs/fig1b.svg',
    caption: 'WeDLM-8B-Instruct와 Qwen3-8B-Instruct를 HumanEval, ARC-C, MMLU, GSM8K, GPQA에서 비교한 레이더 차트입니다.',
    reading: 'WeDLM이 모든 축을 압도한다는 뜻은 아닙니다. 선택된 다섯 벤치마크에서 기반 AR 모델과 비슷하거나 높은 성능을 유지하는지 확인하는 그림입니다.'
  },
  {
    id: '원문 그림 2 — 학습 프레임워크',
    src: 'https://wedlm.github.io/figs/wedlm-training.svg',
    caption: '왼쪽은 관측 토큰을 물리적 앞쪽으로 이동시키되 논리적 위치 ID를 보존하는 Topological Reordering입니다. 오른쪽은 깨끗한 Memory Stream과 마스킹된 Prediction Stream을 연결하는 Dual-Stream Masking입니다.',
    reading: '핵심은 “문장 속 위치”와 “GPU가 계산하는 배열 순서”를 분리하는 것입니다. 마스크 토큰은 인과적 어텐션만 사용하면서도 모든 관측 토큰을 볼 수 있습니다.',
    wide: true
  },
  {
    id: '원문 그림 3 — 블록 디코딩과 스트리밍 디코딩',
    src: 'https://wedlm.github.io/figs/wedlm-inference.svg',
    caption: '고정 블록 방식은 블록 전체가 완성될 때까지 캐시에 넣지 못하지만, WeDLM은 왼쪽부터 확정된 토큰을 즉시 커밋하고 빈 자리에 새 마스크를 보충합니다.',
    reading: '그림의 예에서는 같은 3회 forward로 블록 방식이 3토큰, WeDLM이 6토큰을 확정합니다. 이는 보편적 2배 보장이 아니라 동작 원리를 설명하는 예시입니다.',
    wide: true
  }
];

const equations = [
  {
    id: '수식 1 — 자기회귀 언어모델의 분해',
    formula: String.raw`\[P(\mathbf{x})=\prod_{t=1}^{T}P(x_t\mid x_{<t};\theta)\]`,
    explanation: [
      'AR 모델은 앞에서 생성한 토큰을 조건으로 다음 토큰 하나를 생성합니다. 이 의존 구조 때문에 일반적인 디코딩은 본질적으로 순차적입니다.',
      'KV cache는 이미 처리한 prefix의 key/value를 보존하여 같은 prefix를 다시 계산하지 않도록 합니다.'
    ]
  },
  {
    id: '수식 3 — Masked Diffusion LM의 복원 손실',
    formula: String.raw`\[\mathcal{L}(\theta)=-\mathbb{E}\left[\frac{1}{\gamma}\sum_{i=1}^{L}\mathbf{1}[x_\gamma^{(i)}=\mathrm{[M]}]\log p_\theta(x_0^{(i)}\mid\mathbf{x}_\gamma)\right]\]`,
    explanation: [
      '원문 토큰 일부를 [M]으로 가리고, 가려진 위치의 정답 토큰을 복원하도록 학습합니다.',
      '1/γ는 마스킹 비율이 달라져도 손실 크기가 지나치게 달라지지 않도록 보정합니다.'
    ]
  },
  {
    id: '수식 4 — Prefix Cacheability',
    formula: String.raw`\[p_{\mathrm{cache}}\triangleq\frac{N_{\mathrm{gen}}}{N_{\mathrm{fwd}}}\in(0,1],\qquad \text{평균 재계산 배수}=\frac{1}{p_{\mathrm{cache}}}\]`,
    explanation: [
      'N_gen은 최종적으로 생성된 새 토큰 수이고, N_fwd는 디코딩 과정에서 네트워크가 실제로 처리한 토큰 인스턴스 수입니다.',
      '값이 1에 가까우면 한 번 처리한 토큰이 거의 모두 최종 prefix가 됩니다. 값이 작으면 같은 위치를 여러 번 다시 계산했다는 뜻입니다.'
    ]
  },
  {
    id: '수식 5–6 — 물리적 순서와 논리적 위치의 분리',
    formula: String.raw`\[\tilde{\mathbf{x}}=[x_{o_1},\ldots,x_{o_{N_o}},\mathrm{[M]},\ldots,\mathrm{[M]}],\qquad \tilde{\mathbf{p}}=[o_1,\ldots,o_{N_o},m_1,\ldots,m_{N_m}]\]`,
    explanation: [
      '관측된 토큰을 실제 계산 배열의 앞쪽으로 옮기지만, RoPE에 전달하는 위치 ID는 원래 문장 위치를 유지합니다.',
      '따라서 표준 causal mask에서도 뒤쪽의 마스크 토큰이 앞쪽으로 옮겨진 모든 관측 토큰을 볼 수 있습니다.'
    ]
  },
  {
    id: '수식 10 — Dual-Stream Masking 손실',
    formula: String.raw`\[\mathcal{L}(\theta)=-\mathbb{E}\left[\sum_{k=1}^{K}\frac{1}{\gamma_k}\sum_{j\in\mathcal{M}_k}\log P_\theta\!\left(x_0^{(j)}\mid\mathbf{x}_o^{(<k)},\tilde{\mathbf{x}}_t^{(k,<j)}\right)\right]\]`,
    explanation: [
      'Prediction Stream의 각 블록은 이전 Prediction 블록의 불완전한 출력이 아니라 Memory Stream의 깨끗한 과거를 조건으로 사용합니다.',
      '학습 때는 clean history를 제공하고, 추론 때는 이미 확정된 prefix가 그 역할을 하도록 맞추려는 설계입니다.'
    ]
  },
  {
    id: '수식 11 — 거리 패널티가 포함된 엔트로피',
    formula: String.raw`\[\tilde{H}_i=H_i+\lambda d_i,\qquad H_i=-\sum_v p_i(v)\log p_i(v)\]`,
    explanation: [
      'H_i가 낮을수록 모델이 해당 위치의 토큰을 확신합니다. d_i는 현재 가장 왼쪽 마스크에서 떨어진 거리입니다.',
      'λd_i를 더하면 오른쪽 위치는 선택되기 어려워져, 왼쪽부터 연속된 prefix가 자라도록 유도합니다.'
    ]
  }
];

